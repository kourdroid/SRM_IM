# ONEE SRM Mobile App - Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.

# 1. Supabase Project Credentials
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# 2. Supabase Edge Functions Configuration
EXPO_PUBLIC_VOICE_FUNCTION_URL=https://your-project-id.supabase.co/functions/v1/process-voice

# 3. Optional integrations
EXPO_PUBLIC_N8N_WEBHOOK_URL=https://n8n.example.com/webhook/your-webhook-id
