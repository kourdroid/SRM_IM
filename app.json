{
  "expo": {
    "name": "SRM",
    "slug": "SRM",
    "version": "1.0.5",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "srm",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SRM utilise la caméra pour joindre une photo à un incident terrain.",
        "NSPhotoLibraryUsageDescription": "SRM utilise la galerie pour joindre une photo à un incident terrain.",
        "NSLocationWhenInUseUsageDescription": "SRM utilise la position GPS pour localiser précisément l'incident signalé."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#111827",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.kaliits.srmims",
      "versionCode": 6
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#111827",
          "dark": {
            "backgroundColor": "#111827"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SRM utilise la galerie pour joindre une photo à un incident terrain.",
          "cameraPermission": "SRM utilise la caméra pour joindre une photo à un incident terrain.",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SRM utilise la position GPS pour localiser précisément l'incident signalé."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de57db08-3dc1-463b-80ec-6c9b6debcd62"
      }
    },
    "owner": "kourchal",
    "updates": {
      "url": "https://u.expo.dev/de57db08-3dc1-463b-80ec-6c9b6debcd62"
    }
  }
}
